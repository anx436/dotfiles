# # 2. The Keybinding
# # Press Mod+Shift+Enter (or your choice) to open the prompt
# bindsym $mod+Shift+Return exec kitty --class "quick_cmd" bash -c "read -p 'Command: ' cmd && eval \$cmd"

# Window rule (Identical to before, but maybe slightly taller for Zsh)
for_window [app_id="quick_cmd"] {
    floating enable
    sticky enable
    border pixel 2
    resize set width 600 px height 50 px
    move position center
}

# Binding
# We use 'env QUICK_CMD=1' so Zsh can detect this specific window
bindsym $mod+Shift+Return exec kitty --class "quick_cmd" env QUICK_CMD=1 zsh

# Rules for the terminal
for_window [app_id="floating_shell"] {
    floating enable
    sticky enable
    border pixel 2
    move position center
}

# The Keybind: We tell Kitty exactly how big to be
# -o remember_window_size=no  <-- Vital, otherwise it ignores the width/height
bindsym $mod+b exec kitty --class "floating_shell" \
    -o remember_window_size=no \
    -o initial_window_width=1000 \
    -o initial_window_height=800
