# Function to stop recording any new commands to history
stop_history() {
    # zshaddhistory is the hook called before a command is added to history
    # returning 1 tells zsh to skip it entirely
    zshaddhistory() { return 1 }
}

# open current command prompt in editor
autoload edit-command-line; zle -N edit-command-line
bindkey -M vicmd 'm' edit-command-line

[ -f /opt/miniconda3/etc/profile.d/conda.sh ] && source /opt/miniconda3/etc/profile.d/conda.sh

if [[ -n $QUICK_CMD ]]; then
    # Clear any existing prompt hooks that Manjaro/Powerline might have set
    unset RPOMPT
    
    # Force the prompt to be simple inside the hook
    # This runs right before the cursor appears, overwriting Manjaro's logic
    setup_quick_prompt() {
        PROMPT="> "
        RPROMPT=""
    }

    # Add our setup to the precmd hooks
    autoload -Uz add-zsh-hook
    add-zsh-hook precmd setup_quick_prompt

    # Logic to exit after a command is run
    preexec() {
        _CMD_RAN=1
    }

    # Update the precmd to handle both the exit logic AND the prompt
    precmd() {
        # Only exit if the last command was successful (exit code 0)
        if [[ -n $_CMD_RAN && $? -eq 0 ]]; then
            exit
        elif [[ -n $_CMD_RAN ]]; then
            echo "Command failed! Press Enter to close or try again."
            _CMD_RAN="" # Reset so it doesn't loop exit
        else
            setup_quick_prompt
        fi
    }
fi

